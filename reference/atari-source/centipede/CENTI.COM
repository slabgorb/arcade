!CENTI.COM
ASS RK1 OBJ
ASS RK1 BIN
ASS RK1 IMG
!THE FOLLOWING FLES MAY BE .INCLUDE'D
!IN SOME ASSEMBLIES:
!CENDEF

R MAC65
OBJ:CENTI=CENTI
OBJ:CENIRQ=CENIRQ
OBJ:CENTST=CENTST
OBJ:CENPIC=CENPIC
^C

R LINKM
BIN:CENTI,CENTI.XX=OBJ:CENTI,CENIRQ,CENTST
BIN:CENPIC,CENPIC.XX=OBJ:CENPIC
^C

R IMGFIL
BIN:CENTI
2048
IMG:136001.103
2000
IMG:136001.104
2800
IMG:136001.105
3000
IMG:136001.106
3800
^C
R IMGFIL
BIN:CENPIC
2048
IMG:136001.101
0
IMG:136001.102
800
^C
