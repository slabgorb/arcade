	.SBTTL VGAN - ALPHA-NUMERIC VECTOR SUBROUTINES
;
;DATE INITIATED:	6-JUNE-79
;
;PROJECT CHARGE #:	23803
;
;DISK #:		105, B46
;
;HARDWARE REQUIREMENTS:	STUBBENS AUTO-NORMALIZING VECTOR GENERATOR
;
;MEMORY REQUIREMENTS:	NOT APPLICABLE-SUBROUTINE
;
;INTERRUPT REQUIREMENTS:
;			NOT APPLICABLE-SUBROUTINE
;
;ASSEMBLY COMMAND STRING:
;			NOT APPLICABLE-SUBROUTINE
;			(NEEDS ANVGMC MACROS);
;LINK COMMAND STRING:
;			NOT APPLICABLE-SUBROUTINE
;
;PROGRAM DESCRIPTION:	THIS PROGRAM PROVIDES ALL THE GLOBAL ENTRY POINTS
;			NEEDED BY THE VECTOR UTILITY PROGRAM VGUT.MAC.

	.IIF NDF,.BRITE,.BRITE=4	;DEFINE DEFAULT BRIGHTNESS (0-F)
		
CHAR.A:	VCTR 0,16,.BRITE
	VCTR 8,8,.BRITE
	VCTR 8,-8,.BRITE
	VCTR 0,-16,.BRITE
	VCTR -16,8,0
	VCTR 16,0,.BRITE
	VCTR 8,-8,0
	RTSL
	
CHAR.B:	VCTR 0,24,.BRITE
	VCTR 12,0,.BRITE
