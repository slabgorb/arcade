	VCTR -4,-4,.BRITE
	VCTR -12,0,.BRITE
	VCTR 12,0,0
	VCTR 4,-4,.BRITE
	VCTR 0,-4,.BRITE
	VCTR -4,-4,.BRITE
	VCTR -12,0,.BRITE
	JMPL CHAR.
	
