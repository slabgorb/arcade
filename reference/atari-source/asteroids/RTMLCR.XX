	.TITLE RTMLCR - ASTEROIDS

;ROM TO CASCADE RATE MULTIPLIERS

	.ASECT
	.RADIX 16
	.=1000
	.NLIST BYT
	.LIST MEB
;USES 82S131
;A0	- RATE T IN
;A1	- RATE S IN
;A2	- (ENABLE) AND NOT (COUNT IN)
;A3-A5	- RATE T CARRY IN
;A6-A8	- RATE S CARRY IN
	.REPT 7.
	.REPT 56.
	.BYTE 0
	.ENDR
	.BYTE 1,1,1,1,1,0,1,0
	.ENDR
	.REPT 7
	.BYTE 2,2,2,2,2,2,0,0
	.ENDR
	.BYTE 3,3,3,3,3,2,1,0
	.END
