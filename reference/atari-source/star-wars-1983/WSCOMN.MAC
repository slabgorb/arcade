			.COPY WSMAIN.LNK		;<<<<<<<<<<<
;
;PROGRAM DESCRIPTION:	1ST PERSON SPACESHIP BATTLE.  LICENSED BATTLE
;			AGAINST TIE FIGHTERS AND DEATH STAR.
