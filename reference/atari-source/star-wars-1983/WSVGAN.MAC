	VCTR 0,24,.BRITE
	VCTR 16,0,.BRITE
	JMPL CHARU2
	RTSL
	
CHAR.G:
	VCTR 8,10,0
	VCTR 8,0,.BRITE
	VCTR 0,-10,.BRITE
	VCTR -16,0,0
	JMPL CHAR.C	

CHAR.H:
	VCTR 0,24,.BRITE
	VCTR 0,-12,0
	VCTR 16,0,.BRITE
	VCTR 0,-12,0
	JMPL CHARU1
	
CHAR.I:
	VCTR 16,0,.BRITE
	VCTR -16,24,0
