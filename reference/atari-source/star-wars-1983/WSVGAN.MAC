	VCTR 16,0,.BRITE
	VCTR -8,0,0
	JMPL CHAR11
	
CHAR.J:	VCTR 0,8,0
	VCTR 8,-8,.BRITE
	VCTR 8,0,.BRITE
	JMPL CHARU1
	
CHAR.K:	VCTR 0,24,.BRITE
	VCTR 0,-12,0
	VCTR 16,12,.BRITE
	VCTR -16,-12,0
	VCTR 16,-12,.BRITE
	JMPL CHAR73
	
CHAR.L:	VCTR 0,24,0
	VCTR 0,-24,.BRITE
UNDERL:
	VCTR 16,0,.BRITE
	JMPL CHAR73
	
CHAR.M:	VCTR 0,24,.BRITE
	VCTR 8,-8,.BRITE
	VCTR 8,8,.BRITE
	JMPL CHAR72
	
CHAR.N:	VCTR 0,24,.BRITE
	VCTR 16,-24,.BRITE
	JMPL CHARU1
	
CHAR.O:
	VCTR 16,0,.BRITE
	VCTR 0,24,.BRITE
CHARO2:
	VCTR -16,-24,0
	JMPL CHARF1	

CHAR.:
	VCTR 24,0,0		;BLANK
	RTSL
	
CHAR.P:
	VCTR 0,12,0
	VCTR 16,0,.BRITE
	VCTR 0,12,.BRITE
	JMPL CHARO2

CHAR.Q:
	VCTR 8,8,0
	VCTR 8,-8,.BRITE
	VCTR -16,0,0
	VCTR 8,0,.BRITE
	VCTR 8,8,.BRITE
	VCTR 0,16,.BRITE
	VCTR -16,-24,0
	JMPL CHARF1

CHAR.R:
	VCTR 0,12,0
	VCTR 16,-12,.BRITE
	VCTR -16,0,0
	JMPL CHAR.P

CHAR.S:
	VCTR 16,0,0
	VCTR 0,12,.BRITE
	VCTR -16,0,0
	VCTR 0,12,.BRITE
	JMPL CHAR33
	
CHAR.T:
	VCTR 0,24,0
	JMPL CHARI1
	
CHAR.U:	VCTR 0,24,0
	VCTR 0,-24,.BRITE
	VCTR 16,0,.BRITE
CHARU1:	VCTR 0,24,.BRITE
CHARU2:	VCTR 8,-24,0
	RTSL
	
CHAR.V:	VCTR 0,24,0
	VCTR 8,-24,.BRITE
	VCTR 8,24,.BRITE
	JMPL CHARU2
	
CHAR.W:	VCTR 0,24,0
	VCTR 0,-24,.BRITE
	VCTR 8,8,.BRITE
	VCTR 8,-8,.BRITE
	JMPL CHARU1
	
CHAR.X:	VCTR 16,24,.BRITE
	VCTR -16,0,0
	VCTR 16,-24,.BRITE
	JMPL CHAR73
	
CHAR.Y:
	VCTR 8,0,0
	VCTR 0,16,.BRITE
	VCTR -8,8,.BRITE
	VCTR 8,-8,0
	VCTR 8,8,.BRITE
	JMPL CHARU2
	
CHAR.Z:	VCTR 0,24,0
	VCTR 16,0,.BRITE
	VCTR -16,-24,.BRITE
	JMPL UNDERL
	
CHAR.0	=CHAR.O
	
CHAR.1:
	VCTR 16,0,.BRITE
	VCTR -12,20,0
	VCTR 4,4,.BRITE
CHAR11:
	VCTR 0,-24,.BRITE
CHAR12:
	VCTR 16,0,0
	RTSL
	
CHAR.2:
	VCTR 0,12,.BRITE
	VCTR 16,0,0
	VCTR 0,12,.BRITE
	JMPL CHAR32
	
CHAR.3:
	VCTR 16,0,0
CHAR31:
	VCTR 0,24,.BRITE
CHAR32:
	VCTR -16,0,0
CHAR33:
	VCTR 16,0,.BRITE
	VCTR -16,-12,0
	VCTR 16,0,.BRITE
	VCTR -16,-12,0
	JMPL UNDERL
	
CHAR.4:	VCTR 0,24,0
	VCTR 0,-12,.BRITE
	VCTR 16,0,.BRITE
	VCTR 0,12,0
	JMPL CHAR72
	
CHAR.5	=CHAR.S
	
CHAR.6:
	VCTR 0,12,0
	VCTR 16,0,.BRITE
	VCTR 0,-12,.BRITE
	VCTR -16,0,0
	JMPL CHAR.L
	
CHAR.7:	VCTR 0,24,0
CHAR71:	VCTR 16,0,.BRITE
CHAR72:	VCTR 0,-24,.BRITE
CHAR73:	VCTR 8,0,0
	RTSL
	
CHAR.8:
	VCTR 0,24,.BRITE
	VCTR 16,-24,0
	JMPL CHAR31
	
CHAR.9:
	VCTR 0,24,0
	VCTR 0,-12,.BRITE
	VCTR 16,0,.BRITE
	VCTR -16,12,0
	JMPL CHAR71

				;===
	VJ PERD
CH.PER:	VCTR 0,0,ON		;PERIOD
	JMPL CHAR.

CH.CLN:	VJ COLN			;COLON
	VCTR 8,10,OFF
	VCTR 0,0,ON
	VCTR 0,-10,OFF
	VCTR 0,0,ON
	JMPL CHAR12

CH.APO:	VCTR 10,24,OFF		;APOSTROPHE
	JSRL CH.TIC
	VCTR 14,-24,OFF
	RTSL

CH.CMA:	VCTR 4,0,OFF
	JSRL CH.TIC		;COMMA
	VCTR 20,0,OFF
	RTSL

CH.TIC:	VCTR -4,-10,ON
	VCTR 6,10,ON
	VCTR -2,0,ON
	RTSL

CH.HLF:	VJ HALF			;ONE-HALF
	VCTR 4,16,OFF		;ONE
	VCTR 0,8,ON
	VCTR -4,-24,OFF
	VCTR 12,24,ON		;SLASH
	VCTR -4,-12,OFF
	VCTR 8,0,ON		;TWO ON BOTTOM
	VCTR 0,-6,ON
	VCTR -10,0,ON
	VCTR 0,-6,ON
	VCTR 10,0,ON
	VCTR 8,0,OFF
	RTSL
				;===

CH.COP:				;COPYRIGHT CIRCLE C
	VCTR 8,-6,OFF
				;
	VCTR -8,10,ON
	VCTR 0,16,ON
	VCTR 8,10,ON
	VCTR 16,0,ON
				;START OF C
	VCTR -2,-10,OFF
	VCTR -10,0,ON
	VCTR 0,-18,ON
	VCTR 10,0,ON
				;END OF C
	VCTR -14,-8,OFF	
	VCTR 16,0,ON
	VCTR 8,10,ON
	VCTR 0,16,ON
	VCTR -8,10,ON
				;
	VCTR 0,-30,OFF
	RTSL
				;---
CH.HYP:
	VCTR 2,12,OFF
	VCTR 12,0,ON
	VCTR 10,-12,OFF
	RTSL
				;---

.IF NE,0
CH.LPN:				;LEFT PAREN
	VCTR 12,24,OFF
	VCTR -4,-8,ON
	VCTR 0,-8,ON
	VCTR 4,-8,ON
	VCTR 12,0,OFF
	RTSL

CH.RPN:				;RIGHT PAREN
	VCTR 8,24,OFF
	VCTR 4,-8,ON
	VCTR 0,-8,ON
	VCTR -4,-8,ON
	VCTR 16,0,OFF
	RTSL
.ENDC
	
