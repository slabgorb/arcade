;;;	JSRL	CH.LPN		;LEFT PAREN
;;;	JSRL	CH.RPN		;RIGHT PAREN
	RTSL
				;===
	.PAGE
	.SBTTL	CHARACTER DEFINITIONS
CHAR.A:
	VCTR 0,16,.BRITE
	VCTR 8,8,.BRITE
	VCTR 8,-8,.BRITE
	VCTR 0,-16,.BRITE
	VCTR -16,10,0
	VCTR 16,0,.BRITE
	VCTR 8,-10,0
	RTSL
	
CHAR.B:
	VCTR 0,24,.BRITE
	VCTR 10,0,.BRITE
	VCTR 4,-6,.BRITE
	VCTR -4,-6,.BRITE
	VCTR -10,0,.BRITE
	VCTR 12,0,0
	VCTR 4,-6,.BRITE
	VCTR -4,-6,.BRITE
	VCTR -12,0,.BRITE
	JMPL CHAR.
	
CHAR.C:	VCTR 0,24,.BRITE
	VCTR 16,0,.BRITE
	VCTR -16,-24,0
	JMPL UNDERL
	
CHAR.D:
	VCTR 10,0,.BRITE
	VCTR 6,8,.BRITE
	VCTR 0,8,.BRITE
	VCTR -6,8,.BRITE
	VCTR -10,0,.BRITE
	VCTR 0,-24,.BRITE
	JMPL CHAR.
	
