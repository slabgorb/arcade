	.TITLE MATEST.MAC	.ASECT	.RADIX 16	.ENABL AMA;; PROGRAM TO HELP DEBUG MATRIX PROCESSOR;; HARDWARE: STAR WARS,REV A;; DATE: 12/10/82;	 3/14/83;	 4/4/83;; MAC69;;PROGRAM RAM 4800-4FFF;	.=0A000;MRUN	=4320		;READ,  D7  1=BUSYPCGO	=4700		;WRITE, LOAD MATRIX PROCESSOR PC AND GO (1 BYTE)BIC	=4701		;WRITE, LOAD BLOCK INDEX COUNTER (2 BYTES);XP	=5000		;2 BYTESYP	=5002		;2 BYTESXT	=5018		;2 BYTESYT	=501A		;2 BYTESZT 	=501C		;2 BYTESZERO	=501E		;2 BYTESONE	=5020		;2 BYTES;INIT:	LDS #4FFF;;;;TEST 1 LOOP - LDA ZERO,HALT10$:	LDA #57	STA PCGO	BRA 10$;;TEST 2 LOOP - LDB ZERO,HALT20$:	LDA #58	STA PCGO	BRA 20$;;TEST 3 LOOP - LDC ZERO,MAC,HALT30$:	LDA #59	STA PCGO	BRA 30$;;TEST 4 LOOP - CLA,HALT40$:	LDA #5A	STA PCGO	BRA 40$;;TEST 5 LOOP - IBC,HALT50$:	LDA #5B	STA PCGO	BRA 50$ ;;TEST 6 LOOP - LAC XP;	       SAC YP,HALT60$:	LDD #0AAAA	STD XP	LDA #5C	STA PCGO	NOP	LDD YP		;FOR ANALYZER TRIGGERING	LDD #5555	STD XP	LDA #5C	STA PCGO	NOP	LDD YP		;FOR ANALYZER TRIGGERING	BRA 60$;;;TEST 7 LOOP -  LDA XT,CLA;		LDB YT;		LDC ZT,MAC;		SAC XP,HALT;;4000*4000=4000;70$:	LDD #4000	STD XT	LDD #0000	STD YT	LDD #4000	STD ZT	LDA #5D	STA PCGO71$:	TST MRUN	BMI 71$	LDD XP	BRA 70$;;TEST 8 TESTS ACCUMULATOR;		LDA XT;		LDB YT;		LDC ZT,MAC;		SAC XP,HALT;80$:	LDA #5A		;FIRST CLEAR ACCUMULATOR	STA PCGO81$:	LDD #0100	;EVERY TIME THIS PART IS RUN 	STD XT		;THE PRODUCT SHOULD ACCUMULATE	LDD #0000	STD YT	LDD #4000	STD ZT82$:	LDA #5E	STA PCGO83$:	TST MRUN	BMI 83$	LDD XP		;TRIGGER ANALYZER 	BRA 82$	;;TEST 9 - TEST BLOCK INDEX COUNTER;		LDA X,IND,CLA;		LDB ZERO;		LDC ONE,MAC;		SAC XP,HALT;90$:	LDX #6000	;ZERO THE MATH RAM 5000-5FFF	LDD #000091$:		STD --(X)	CMPX #4FFE	BNE 91$	LDD #4000	STD ONE	LDD #0001	;THE SECOND BLOCK	STD BIC	LDD #0AAAA	STD 5008	LDA #5F	STA PCGO92$:	TST MRUN	BMI 92$	LDD XP	LDD #01FF	;THE LAST BLOCK (512)	STD BIC	LDD #5555	STD 5FF8	LDA #5F	STA PCGO93$:	TST MRUN	BMI 93$	LDD XP	BRA 90$;;	.END