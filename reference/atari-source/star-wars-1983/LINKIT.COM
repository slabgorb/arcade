$  SAY "LINK THE OVERLAY FIRST,GET ITS SYMBOL TABLE"
$  SAY "UNDEFINEDS ARE OK FOR THIS EARLY"
$  LINKM WSOVLX/S/R/NP
$  SAY "NOW LINK ROOT WITH OVLYS SYMBOLS"
$  SAY "	NO ERRORS ALLOWED FOR THIS LINK"
$  LINKM WSROOT/S/R/NP
$  SAY "NOW BACK TO OVERLAY TO FIX ITS UNDEFINEDS"
$  SAY "	MULTIPLE DEFINED LABELS OK"
$  LINKM WSOVLY/NP
$  SAY "ALL DONE, CHECK MAP FOR ERRORS"
$  EXIT
